{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "compile",
      "path": "extension",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc",
      "label": "npm: compile - extension",
      "detail": "tsc -p ./"
    },
    {
      "type": "npm",
      "script": "watch",
      "path": "extension",
      "isBackground": true,
      "group": "build",
      "problemMatcher": {
        "owner": "noggin-esbuild",
        "source": "esbuild",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^(\\S+):(\\d+):(\\d+): (error|warning): (.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "esbuild watching",
          "endsPattern": "Done in \\d"
        }
      },
      "label": "npm: watch - extension",
      "detail": "node esbuild.mjs --watch (host + webview)"
    },
    {
      "type": "shell",
      "label": "noggin: sync skill",
      "command": "node",
      "args": ["scripts/sync-skill.mjs"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "docs: build site",
      "command": "node",
      "args": ["docs/site/build.mjs", "--out", "docs/site/dist"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "docs: serve site",
      "detail": "Build docs site and serve at http://localhost:8080/ (--watch rebuilds on edits).",
      "command": "node",
      "args": ["docs/site/serve.mjs", "--watch"],
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
