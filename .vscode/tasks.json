{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "compile",
      "path": "extension",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc",
      "label": "npm: compile - extension",
      "detail": "tsc -p ./"
    },
    {
      "type": "npm",
      "script": "watch",
      "path": "extension",
      "isBackground": true,
      "group": "build",
      "problemMatcher": "$tsc-watch",
      "label": "npm: watch - extension",
      "detail": "tsc -watch -p ./"
    },
    {
      "type": "shell",
      "label": "noggin: sync skill",
      "command": "node",
      "args": ["scripts/sync-skill.mjs"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "docs: build site",
      "command": "node",
      "args": ["docs/site/build.mjs", "--out", "docs/site/dist"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "docs: serve site",
      "detail": "Build docs site and serve at http://localhost:8080/ (--watch rebuilds on edits).",
      "command": "node",
      "args": ["docs/site/serve.mjs", "--watch"],
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": "^([^\\n]+)$",
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^building",
          "endsPattern": "^serving "
        }
      }
    }
  ]
}
