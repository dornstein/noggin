{
  "name": "noggin-desktop",
  "version": "0.5.1",
  "private": true,
  "description": "Noggin desktop app — Windows-first, super lightweight, auto-updating.",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "icon": "pwsh -NoProfile -File scripts/generate-icon.ps1",
    "package": "npm run build && electron-builder --dir",
    "release": "npm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@noggin/ui": "file:../ui",
    "electron-updater": "^6.3.9",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@noggin/engine": "file:../engine",
    "@noggin/rpc": "file:../rpc",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "dornstein",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dornstein/noggin.git",
    "directory": "desktop"
  }
}
