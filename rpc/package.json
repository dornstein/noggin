{
  "name": "@noggin/rpc",
  "version": "0.4.29",
  "private": true,
  "description": "Transport-agnostic RPC protocol for noggin. Generic request/response/notification machinery plus pluggable transports (memory, electron-ipc, postMessage). The noggin-rpc protocol surface is defined here as TypeScript types; engine wiring lives in @noggin/rpc-server (Phase 2).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./transports/memory": "./src/transports/memory.ts",
    "./transports/electron-ipc": "./src/transports/electron-ipc.ts",
    "./transports/postmessage": "./src/transports/postmessage.ts"
  },
  "sideEffects": false,
  "files": [
    "src/**/*",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@noggin/engine": "file:../engine",
    "@types/node": "^20",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
