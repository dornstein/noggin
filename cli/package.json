{
  "name": "noggin-cli",
  "version": "0.5.1",
  "description": "A working-memory tree CLI for in-flight work.",
  "type": "module",
  "bin": {
    "noggin": "./dist/noggin.mjs"
  },
  "main": "./dist/noggin.mjs",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@noggin/engine": "file:../engine",
    "esbuild": "^0.25.12"
  },
  "scripts": {
    "test": "node --check noggin.mjs && node --test test/*.test.mjs",
    "build": "node ../scripts/build-mcp-bundle.mjs noggin.mjs dist/noggin.mjs",
    "prepack": "npm run build"
  },
  "keywords": [
    "noggin",
    "todo",
    "working-memory",
    "agent-skill",
    "copilot"
  ],
  "author": "dornstein",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dornstein/noggin.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/dornstein/noggin#readme",
  "bugs": {
    "url": "https://github.com/dornstein/noggin/issues"
  }
}
