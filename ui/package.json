{
  "name": "@noggin/ui",
  "version": "0.4.41",
  "private": true,
  "description": "Reusable React components for noggin UIs (tree, details, quick-add, notes editor). Consumed by the VS Code extension, the desktop app, and the docs site playground.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./gestures": "./src/gestures.ts",
    "./contrast-check": "./src/contrast-check.ts",
    "./styles.css": "./src/styles.css",
    "./tokens.css": "./src/tokens.css",
    "./themes/light.css": "./src/themes/light.css",
    "./themes/dark.css": "./src/themes/dark.css",
    "./themes/vscode.css": "./src/themes/vscode.css",
    "./themes/auto.css": "./src/themes/auto.css"
  },
  "sideEffects": [
    "./src/styles.css",
    "./src/tokens.css",
    "./src/themes/*.css"
  ],
  "files": [
    "src/**/*",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ct": "playwright test --config=playwright-ct.config.ts",
    "test:ct:ui": "playwright test --config=playwright-ct.config.ts --ui",
    "test:ct:install": "playwright install --with-deps chromium"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.30.0",
    "@radix-ui/react-context-menu": "^2.3.1",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@vscode/codicons": "^0.0.36",
    "marked": "^15.0.0",
    "react-arborist": "^3.4.0"
  },
  "devDependencies": {
    "@noggin/engine": "file:../engine",
    "@noggin/rpc": "file:../rpc",
    "@playwright/experimental-ct-react": "^1.61.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
